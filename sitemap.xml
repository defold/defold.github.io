---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
	{%- for post in site.posts -%}
	{%- unless post.published == false -%}
	<url>
		<loc>{{ site.url }}{{ post.url }}</loc>
		<lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
		<changefreq>monthly</changefreq>
		<priority>0.6</priority>
	</url>
	{%- endunless -%}
	{%- endfor -%}
	{%- for page in site.pages -%}
	{%- unless page.pagefind_exclude -%}
	{%- assign page_url = page.url | remove: "index.html" -%}
	<url>
		<loc>{{ site.url }}{{ page_url }}</loc>
		{%- if page.date -%}
		<lastmod>{{ page.date | date_to_xmlschema }}</lastmod>
		{%- endif -%}
		{%- if page_url == "/" -%}
		<changefreq>weekly</changefreq>
		<priority>1.0</priority>
		{%- elsif page_url == "/download/" or page_url == "/product/" or page_url == "/manuals/" or page_url == "/tutorials/" or page_url == "/examples/" or page_url == "/assets/" or page_url == "/showcase/" or page_url == "/blog/" or page_url == "/news/" -%}
		<changefreq>weekly</changefreq>
		<priority>0.8</priority>
		{%- else -%}
		<changefreq>monthly</changefreq>
		<priority>0.5</priority>
		{%- endif -%}
	</url>
	{%- endunless -%}
	{%- endfor -%}
</urlset>

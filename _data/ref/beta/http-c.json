        {
            "brief": "HTTP response callback",
            "description": "Called from the HTTP client worker thread. HTTP_RESPONSE_EVENT_DATA events\nare sent as response chunks arrive; the receiver is responsible for\nprocessing or copying them before returning. The receiver is also responsible\nfor synchronizing with other threads. Pointers in HttpResponseInfo are valid\nonly for the duration of the callback. Returning HTTP_CALLBACK_RESULT_CANCEL\nfrom header, data, or progress events cancels the request.",
            "error": "",
            "examples": "",
            "language": "",
            "members": [],
            "name": "HttpResponseCallback",
            "notes": [],
            "parameters": [
                {
                    "doc": "Request object. Valid only for the duration of the callback.",
                    "is_optional": "False",
                    "name": "request",
                    "types": [
                        "HttpRequest*"
                    ]
                },
